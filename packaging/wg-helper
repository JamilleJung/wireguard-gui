#!/bin/bash
# wg-helper — the single privileged entry point for wireguard-gui.
#
# The GUI runs as a normal user and invokes:  sudo -n wg-helper <verb> [name]
# Only this one script is whitelisted NOPASSWD in /etc/sudoers.d/wireguard-gui,
# so the attack surface is exactly the verbs below (all tunnel names are
# validated against a strict charset before touching the filesystem).
set -euo pipefail

WG_DIR="${WG_DIR:-/etc/wireguard}"

die() { echo "wg-helper: $*" >&2; exit 2; }

# Tunnel names must be a valid interface name fragment: letters, digits,
# underscore, hyphen, dot — 1..15 chars (Linux IFNAMSIZ - 1).
validate_name() {
    [[ "$1" =~ ^[A-Za-z0-9_.-]{1,15}$ ]] || die "invalid tunnel name: $1"
}

verb="${1:-}"
[[ -n "$verb" ]] || die "no verb"
shift || true

case "$verb" in
    list)
        # Names of every .conf in the wireguard dir, one per line.
        [[ -d "$WG_DIR" ]] || exit 0
        find "$WG_DIR" -maxdepth 1 -type f -name '*.conf' -printf '%f\n' 2>/dev/null \
            | sed 's/\.conf$//' | sort
        ;;
    active)
        # Interface names that are currently up.
        wg show interfaces 2>/dev/null || true
        ;;
    read)
        validate_name "${1:-}"
        cat "$WG_DIR/$1.conf"
        ;;
    dump)
        validate_name "${1:-}"
        # Machine-readable live status; empty if the iface is down.
        wg show "$1" dump 2>/dev/null || true
        ;;
    up)
        validate_name "${1:-}"
        wg-quick up "$1"
        ;;
    down)
        validate_name "${1:-}"
        wg-quick down "$1"
        ;;
    save)
        # Content comes from stdin. Written atomically with 0600 perms.
        validate_name "${1:-}"
        umask 077
        tmp="$WG_DIR/.$1.conf.tmp.$$"
        cat > "$tmp"
        chmod 600 "$tmp"
        mv -f "$tmp" "$WG_DIR/$1.conf"
        ;;
    delete)
        validate_name "${1:-}"
        wg-quick down "$1" 2>/dev/null || true
        rm -f "$WG_DIR/$1.conf"
        ;;
    enable)
        validate_name "${1:-}"
        systemctl enable "wg-quick@$1" >/dev/null 2>&1
        ;;
    disable)
        validate_name "${1:-}"
        systemctl disable "wg-quick@$1" >/dev/null 2>&1
        ;;
    is-enabled)
        validate_name "${1:-}"
        systemctl is-enabled "wg-quick@$1" 2>/dev/null || true
        ;;
    *)
        die "unknown verb: $verb"
        ;;
esac
