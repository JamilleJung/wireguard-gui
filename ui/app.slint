import { ListView, ScrollView, LineEdit, TextEdit, Palette, CheckBox } from "std-widgets.slint";
import { StatusDot } from "components/statusdot.slint";


// ---- data shared with the Rust backend ------------------------------------

export struct TunnelItem {
    name: string,
    active: bool,
}

export struct PeerInfo {
    public-key: string,
    preshared: bool,
    allowed-ips: string,
    endpoint: string,
    keepalive: string,
    latest-handshake: string,
    transfer: string,
}

export struct CheckItem {
    name: string,
    detail: string,
    ok: bool,
    warn: bool,
}

export struct BackupRow {
    name: string,
    date: string,
    size: string,
    count: string,
}

// One styled line of a lightweight-rendered markdown doc (Help / changelog).
// `kind` selects the MdRow styling: "h1" "h2" "h3" "bullet" "quote" "code"
// "rule" "blank" "normal". `text` is already stripped of markdown markers in
// Rust (md_items), so MdRow only styles — it never re-parses.
export struct DocItem {
    text: string,
    kind: string,
}

export struct TunnelDetail {
    name: string,
    active: bool,
    autostart: bool,
    killswitch: bool,
    public-key: string,
    listen-port: string,
    addresses: string,
    dns: string,
    peers: [PeerInfo],
    // Live connection health + throughput (filled by the background poller).
    health: string,
    health-good: bool,
    speed: string,
}

// ---- small reusable pieces -------------------------------------------------

// Drives the single top-level tooltip overlay in MainWindow. Hovering a button
// reports its label + window-space geometry here; the overlay renders above all
// other content (so it can never be clipped by, or bleed across, neighbours).
global TooltipState {
    in-out property <string> text;
    in-out property <length> ax;   // hovered button's left edge, window coords
    in-out property <length> ay;   // hovered button's top edge, window coords
    in-out property <length> aw;   // hovered button's width
}

// A Windows-style push button. Icons are drawn (vector) so they render
// regardless of the system font.
component PushButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary;
    in property <bool> enabled: true;
    in property <bool> arrow;          // show a dropdown triangle
    in property <string> tooltip: "";
    in property <string> tooltip-align: "left";   // "left" | "right"
    callback clicked;

    min-width: label.preferred-width + (root.arrow ? 40px : 26px);
    max-width: label.preferred-width + (root.arrow ? 56px : 42px);
    height: 29px;
    vertical-stretch: 0;
    horizontal-stretch: 0;
    border-radius: 3px;
    border-width: 1px;
    background: !root.enabled ? #f3f3f3
        : root.primary ? (ta.pressed ? #005a9e : (ta.has-hover ? #1a86d9 : #0078d4))
        : (ta.pressed ? #d6d6d6 : (ta.has-hover ? #e9f3fc : #fdfdfd));
    border-color: !root.enabled ? #e0e0e0
        : root.primary ? (ta.has-hover ? #1a86d9 : #0078d4)
        : (ta.has-hover ? #7fb6e6 : #c4c4c4);

    label := Text {
        x: root.arrow ? (parent.width - self.width - 14px) / 2 : (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: root.text;
        font-size: 13px;
        color: !root.enabled ? #a6a6a6 : (root.primary ? white : #1b1b1b);
    }

    // dropdown triangle
    if root.arrow: Path {
        x: label.x + label.width + 7px;
        y: (parent.height - self.height) / 2 + 1px;
        width: 9px;
        height: 5px;
        viewbox-width: 9;
        viewbox-height: 5;
        fill: root.primary ? white : #444444;
        commands: "M 0 0 L 9 0 L 4.5 5 Z";
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }

    // Report hover into the top-level TooltipState global, which drives a single
    // overlay in MainWindow that renders above everything (so it never clips or
    // bleeds across neighbours, unlike a child Rectangle would).
    property <bool> tip-hover: ta.has-hover;
    changed tip-hover => {
        if (root.tooltip != "") {
            if (root.tip-hover) {
                TooltipState.text = root.tooltip;
                TooltipState.ax = root.absolute-position.x;
                TooltipState.ay = root.absolute-position.y;
                TooltipState.aw = root.width;
            } else if (TooltipState.text == root.tooltip) {
                TooltipState.text = "";
            }
        }
    }
}

// A small square icon button. kind = "delete", "new", "export", or "menu".
component IconButton inherits Rectangle {
    in property <bool> enabled: true;
    in property <string> kind: "delete";
    in property <string> tooltip: "";
    property <bool> danger: root.kind == "delete";
    callback clicked;
    width: 29px;
    height: 29px;
    border-radius: 3px;
    border-width: 1px;
    background: !root.enabled ? #f3f3f3
        : (ta.pressed ? (root.danger ? #e7c4c4 : #d6d6d6)
        : (ta.has-hover ? (root.danger ? #fbeaea : #eef3f9) : #fdfdfd));
    border-color: !root.enabled ? #e0e0e0
        : (ta.has-hover ? (root.danger ? #d98a8a : #7fb6e6) : #c4c4c4);

    // delete: an ✕
    if root.kind == "delete": Path {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 11px;
        height: 11px;
        viewbox-width: 11;
        viewbox-height: 11;
        stroke: root.enabled ? #b23b3b : #bcbcbc;
        stroke-width: 1.6px;
        commands: "M 1 1 L 10 10 M 10 1 L 1 10";
    }
    // export: a download arrow into a tray
    if root.kind == "new": Path {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 13px;
        height: 13px;
        viewbox-width: 13;
        viewbox-height: 13;
        stroke: root.enabled ? #2f7d32 : #bcbcbc;
        stroke-width: 1.5px;
        commands: "M 6.5 1.5 L 6.5 11.5 M 1.5 6.5 L 11.5 6.5";
    }
    // menu: a hamburger — three evenly-spaced horizontal bars
    if root.kind == "menu": Path {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 14px;
        height: 11px;
        viewbox-width: 14;
        viewbox-height: 11;
        stroke: root.enabled ? #444444 : #bcbcbc;
        stroke-width: 1.6px;
        commands: "M 1 1.5 L 13 1.5 M 1 5.5 L 13 5.5 M 1 9.5 L 13 9.5";
    }
    if root.kind == "export": Path {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 13px;
        height: 13px;
        viewbox-width: 13;
        viewbox-height: 13;
        stroke: root.enabled ? #3a6ea5 : #bcbcbc;
        stroke-width: 1.4px;
        commands: "M 6.5 1 L 6.5 8 M 3 5 L 6.5 8.5 L 10 5 M 1.5 11.5 L 11.5 11.5";
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }

    // Report hover into the top-level TooltipState global (see PushButton): the
    // single MainWindow overlay renders above everything, so it never clips or
    // bleeds across buttons the way a child Rectangle did.
    property <bool> tip-hover: ta.has-hover;
    changed tip-hover => {
        if (root.tooltip != "") {
            if (root.tip-hover) {
                TooltipState.text = root.tooltip;
                TooltipState.ax = root.absolute-position.x;
                TooltipState.ay = root.absolute-position.y;
                TooltipState.aw = root.width;
            } else if (TooltipState.text == root.tooltip) {
                TooltipState.text = "";
            }
        }
    }
}

// A "label : value" line. Clicking the value or the trailing icon copies it.
component DetailRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    in property <string> copy-value: root.value;
    in property <bool> copyable: false;
    callback copy(string);
    spacing: 8px;
    Text {
        text: root.label;
        width: 132px;
        color: #6a6a6a;
        font-size: 13px;
        horizontal-alignment: right;
        vertical-alignment: top;
    }
    if root.copyable: HorizontalLayout {
        spacing: 2px;
        horizontal-stretch: 1;
        alignment: start;
        TouchArea {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            clicked => { root.copy(root.copy-value); }
            Text {
                text: root.value;
                color: #1b1b1b;
                font-size: 13px;
                wrap: word-wrap;
                horizontal-alignment: left;
                vertical-alignment: top;
            }
        }
        Text {
            text: "⧉";
            font-size: 12px;
            color: #aaa;
            vertical-alignment: center;
            width: 16px;
            horizontal-alignment: center;
        }
    }
    if !root.copyable: Text {
        text: root.value;
        color: #1b1b1b;
        font-size: 13px;
        horizontal-stretch: 1;
        wrap: word-wrap;
    }
}

// A titled, bordered group box (the "Interface" / "Peer" cards).
component Card inherits Rectangle {
    in property <string> title;
    background: white;
    border-color: #e3e3e3;
    border-width: 1px;
    border-radius: 3px;
    VerticalLayout {
        padding: 14px;
        spacing: 7px;
        Text {
            text: root.title;
            font-size: 14px;
            font-weight: 700;
            color: #202020;
        }
        @children
    }
}

// One row in the left-hand tunnel list.
component TunnelRow inherits Rectangle {
    in property <TunnelItem> item;
    in property <bool> selected;
    callback clicked;
    height: 40px;
    background: selected ? #cce8ff : (touch.has-hover ? #f1f1f1 : transparent);
    border-color: selected ? #99d1ff : transparent;
    border-width: 1px;
    border-radius: 2px;
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 10px;
        spacing: 10px;
        VerticalLayout {
            alignment: center;
            StatusDot { on: item.active; }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: item.name;
                font-size: 14px;
                color: #1b1b1b;
                overflow: elide;
            }
        }
    }
}

// A menu entry inside the "Add Tunnel" popup.
component MenuItem inherits Rectangle {
    in property <string> text;
    callback chosen;
    height: 34px;
    background: t.has-hover ? #2f6fd6 : white;
    t := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.chosen(); }
    }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 18px;
        VerticalLayout {
            alignment: center;
            Text {
                text: root.text;
                font-size: 13px;
                color: t.has-hover ? white : #1b1b1b;
            }
        }
    }
}

// One line in a virtualized doc view (Log / changelog / Help / Diagnostics).
// Click-to-copy: clicking the row copies its text via the `copy` callback and
// shows a subtle hover highlight, restoring copy without a laggy whole-document
// TextEdit.
component DocLine inherits Rectangle {
    in property <string> text;
    callback copy(string);
    height: 16px;
    background: line-touch.has-hover ? #eef3fc : transparent;
    line-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.copy(root.text); }
    }
    HorizontalLayout {
        padding-left: 8px;
        Text {
            text: root.text;
            font-family: "monospace";
            font-size: 12px;
            vertical-alignment: center;
            overflow: clip;
        }
    }
}

// One lightly-styled line of a rendered-markdown doc (Help / changelog). Mirrors
// DocLine's click-to-copy + hover highlight, but styles the row by `item.kind`
// (headings/bullets/quotes/code/rules). The text is wrapped (word-wrap) and the
// row height is CONTENT-driven, so long wrapped lines stay fully visible — these
// docs are bounded (Help ~150 lines, changelog ~120), unlike the Log.
component MdRow inherits Rectangle {
    in property <DocItem> item;
    callback copy(string);
    // Non-interactive spacers don't get a pointer/hover (blank & rule).
    property <bool> interactive: item.kind != "blank" && item.kind != "rule";
    // Size the row to its content. A bare Rectangle does NOT auto-size to its
    // children, so WITHOUT a height every row collapses to 0px and the whole
    // view renders blank (the bug we hit). The max() gives a guaranteed non-zero
    // floor per kind AND grows to fit word-wrapped lines.
    height: max(item.kind == "blank" ? 8px : (item.kind == "rule" ? 14px : 18px), body.preferred-height);
    background: row-touch.has-hover && interactive ? #eef3fc
        : (item.kind == "code" ? #f3f3f3 : transparent);
    row-touch := TouchArea {
        mouse-cursor: interactive ? pointer : default;
        enabled: interactive;
        clicked => { root.copy(item.text); }
    }

    body := VerticalLayout {
        // A rule renders as a thin hairline; a blank line as a small spacer.
        if item.kind == "rule": HorizontalLayout {
            padding-top: 7px;
            padding-bottom: 7px;
            padding-left: 8px;
            padding-right: 8px;
            Rectangle { height: 1px; background: #e0e0e0; }
        }
        if item.kind == "blank": Rectangle { height: 8px; }

        if item.kind != "rule" && item.kind != "blank": HorizontalLayout {
            padding-top: item.kind == "h1" ? 8px : (item.kind == "h2" ? 6px : 3px);
            padding-bottom: 3px;
            // Indent bullets and quotes; "  ◦ " nested bullets carry their own
            // leading spaces, so the base indent stays the same.
            padding-left: item.kind == "bullet" ? 22px : (item.kind == "quote" ? 26px : 8px);
            padding-right: 10px;
            Text {
                text: item.text;
                wrap: word-wrap;
                horizontal-stretch: 1;
                font-family: item.kind == "code" ? "monospace" : "Noto Sans";
                font-size: item.kind == "h1" ? 20px
                    : (item.kind == "h2" ? 16px
                    : (item.kind == "h3" ? 14px
                    : (item.kind == "code" ? 12px : 13px)));
                font-weight: item.kind == "h1" || item.kind == "h2" || item.kind == "h3" ? 700 : 400;
                color: item.kind == "h3" ? #444444
                    : (item.kind == "quote" ? #6a6a6a
                    : (item.kind == "code" ? #b23b3b : #1b1b1b));
            }
        }
    }
}

// A top tab (Tunnels / Log), Windows-style with an accent underline.
component TabButton inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback clicked;
    height: 34px;
    background: ta.has-hover ? #ececec : transparent;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        VerticalLayout {
            alignment: center;
            Text {
                text: root.text;
                font-size: 13px;
                color: root.selected ? #0067c0 : #444444;
            }
        }
    }
    Rectangle {
        y: parent.height - 2px;
        height: 2px;
        background: root.selected ? #0067c0 : transparent;
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// ---- main window -----------------------------------------------------------

export component MainWindow inherits Window {
    title: "WireGuard";
    default-font-family: "Noto Sans";
    default-font-size: 13px;
    preferred-width: 1000px;
    preferred-height: 720px;
    min-width: 720px;
    min-height: 480px;
    background: white;

    // ---- state driven by Rust ----
    in property <[TunnelItem]> tunnels;
    in-out property <int> selected-index: -1;
    in property <bool> has-selection: false;
    in property <TunnelDetail> detail;
    in property <string> status: "";
    // Set when the selected tunnel is active but not actually connected (no
    // handshake) — drives the amber stuck-handshake banner in the detail card.
    in property <string> conn-warning: "";

    // tabs (0 = Tunnels, 1 = Log, 2 = Backup) + log contents
    in-out property <int> active-tab: 0;
    // The log is shown as a virtualized ListView of one Text per line (fed a
    // [string] model from Rust) instead of a single huge read-only TextEdit —
    // TextEdit/ScrollView aren't virtualized, so the whole buffer was relaid
    // out + reshaped every frame while scrolling (and a focused read-only
    // TextEdit runs a repeating blink-caret Timer that repaints when idle).
    in property <[string]> log-lines;
    // Log management: a substring filter and a "this tunnel only" toggle that
    // Rust applies to the raw journal text.
    in-out property <string> log-filter: "";
    in-out property <bool> log-this-tunnel: false;

    // Backup manager: the archive list + which row is selected.
    in property <[BackupRow]> backups;
    in-out property <int> backup-sel: -1;

    // Progressive disclosure for expert/raw runtime actions in the detail card:
    // they live under an always-visible "Advanced ▾" header the user can expand
    // per need. No global mode — nothing is silently hidden.
    in-out property <bool> show-advanced: false;

    // Auto-update: a thin banner above the tab bar, shown only when a newer
    // release was detected. Rust fills in the message and flips the flag.
    in property <bool> update-available: false;
    in property <string> update-banner: "";

    // ---- callbacks into Rust ----
    callback persist-advanced(bool);
    callback select(int);
    callback activate(string);
    callback deactivate(string);
    callback diagnose-conn(string);
    callback import-file();
    callback add-empty();
    callback delete-tunnel(string);
    callback begin-edit(string);
    callback refresh-log();
    callback export-zip();
    callback import-qr();
    callback show-qr(string);
    callback set-autostart(string, bool);
    callback set-killswitch(string, bool);
    callback copy-value(string);
    callback copy-raw(string);
    callback show-about();
    callback show-help();
    callback show-update();
    callback persist-live(string);
    callback show-running(string);
    // Log management
    callback apply-log-filter();
    callback save-log();
    callback copy-log();
    callback copy-line(string);
    callback clear-log();
    // Backup management
    callback refresh-backups();
    callback backup-create();
    callback backup-restore(string);
    callback backup-delete(string);
    callback backup-export(string);

    // Force the light palette app-wide (Palette is a global). Without this,
    // GNOME dark mode gives std-widgets near-white fills that vanish on our
    // white backgrounds.
    init => { Palette.color-scheme = ColorScheme.light; }

    VerticalLayout {
        spacing: 0px;

        // ===================== update banner =====================
        // A thin, unobtrusive row shown only when a newer release was found.
        if root.update-available: Rectangle {
            height: 30px;
            background: #fff4d6;
            Rectangle { y: parent.height - 1px; height: 1px; background: #e6d9a8; }
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: root.update-banner;
                    color: #6a5300;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                VerticalLayout {
                    alignment: center;
                    PushButton {
                        text: "Update now";
                        primary: true;
                        clicked => { root.show-update(); }
                    }
                }
            }
        }

        // ===================== tab bar =====================
        Rectangle {
            height: 35px;
            background: #f3f3f3;
            Rectangle { y: parent.height - 1px; height: 1px; background: #e0e0e0; }
            HorizontalLayout {
                alignment: start;
                TabButton {
                    text: "Tunnels";
                    selected: root.active-tab == 0;
                    clicked => { root.active-tab = 0; }
                }
                TabButton {
                    text: "Log";
                    selected: root.active-tab == 1;
                    clicked => { root.active-tab = 1; root.refresh-log(); }
                }
                TabButton {
                    text: "Backup";
                    selected: root.active-tab == 2;
                    clicked => { root.active-tab = 2; root.refresh-backups(); }
                }
            }
        }

        // ===================== Tunnels tab =====================
        if root.active-tab == 0: HorizontalLayout {
        vertical-stretch: 1;
        spacing: 0px;

        // ===================== left: tunnel list =====================
        Rectangle {
            width: 270px;
            background: white;
            // right divider
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: #e0e0e0;
            }
            VerticalLayout {
                padding: 0px;

                ListView {
                    vertical-stretch: 1;
                    for t[i] in root.tunnels: TunnelRow {
                        item: t;
                        selected: i == root.selected-index;
                        clicked => { root.select(i); }
                    }
                }

                // bottom action bar
                Rectangle {
                    height: 46px;
                    background: #fafafa;
                    Rectangle {
                        y: 0;
                        height: 1px;
                        background: #e0e0e0;
                    }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Add Tunnel";
                                arrow: true;
                                tooltip: "Import or create a tunnel";
                                clicked => { add-popup.show(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            IconButton {
                                kind: "menu";
                                tooltip: "Help, updates & about";
                                clicked => { menu-popup.show(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "?";
                                tooltip: "Help guide";
                                clicked => { root.show-help(); }
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            IconButton {
                                enabled: root.has-selection;
                                tooltip: "Delete this tunnel";
                                clicked => { root.delete-tunnel(root.detail.name); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            IconButton {
                                kind: "export";
                                tooltip: "Export all tunnels";
                                clicked => { root.export-zip(); }
                            }
                        }
                    }

                    add-popup := PopupWindow {
                        x: 8px;
                        y: -116px;
                        width: 244px;
                        height: 110px;
                        Rectangle {
                            background: white;
                            border-color: #b9b9b9;
                            border-width: 1px;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: #00000030;
                            VerticalLayout {
                                padding: 1px;
                                MenuItem {
                                    text: "Import tunnel(s) from file…";
                                    chosen => { add-popup.close(); root.import-file(); }
                                }
                                MenuItem {
                                    text: "Import from QR code…";
                                    chosen => { add-popup.close(); root.import-qr(); }
                                }
                                MenuItem {
                                    text: "Create tunnel…";
                                    chosen => { add-popup.close(); root.add-empty(); }
                                }
                            }
                        }
                    }

                    // App-level menu (Help / Updates / About) — kept separate
                    // from "Add Tunnel", which only creates tunnels. Anchored to
                    // the "≡" button.
                    menu-popup := PopupWindow {
                        x: 108px;
                        y: -116px;
                        width: 200px;
                        height: 110px;
                        Rectangle {
                            background: white;
                            border-color: #b9b9b9;
                            border-width: 1px;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: #00000030;
                            VerticalLayout {
                                padding: 1px;
                                MenuItem {
                                    text: "Help…";
                                    chosen => { menu-popup.close(); root.show-help(); }
                                }
                                MenuItem {
                                    text: "Check for updates…";
                                    chosen => { menu-popup.close(); root.show-update(); }
                                }
                                MenuItem {
                                    text: "About…";
                                    chosen => { menu-popup.close(); root.show-about(); }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ===================== right: details =====================
        Rectangle {
            background: #f6f6f6;
            horizontal-stretch: 1;
            VerticalLayout {

            // empty state - beginner-friendly when there are no tunnels at all
            if !root.has-selection: VerticalLayout {
                vertical-stretch: 1;
                alignment: center;
                spacing: 12px;
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: root.tunnels.length == 0 ? "No tunnels yet" : "Select a tunnel on the left";
                        color: #1b1b1b;
                        font-size: 18px;
                        font-weight: 700;
                    }
                }
                if root.tunnels.length == 0: HorizontalLayout {
                    alignment: center;
                    Text {
                        text: "Import a WireGuard .conf file or a QR-code image to begin.";
                        color: #6a6a6a;
                        font-size: 13px;
                    }
                }
                if root.tunnels.length == 0: HorizontalLayout {
                    alignment: center;
                    spacing: 8px;
                    PushButton {
                        text: "Import .conf";
                        primary: true;
                        clicked => { root.import-file(); }
                    }
                    PushButton {
                        text: "Import QR image";
                        clicked => { root.import-qr(); }
                    }
                    PushButton {
                        text: "New tunnel";
                        clicked => { root.add-empty(); }
                    }
                }
            }

            // detail view
            if root.has-selection: ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    padding: 16px;
                    spacing: 14px;
                    alignment: start;

                    // ---- Interface card ----
                    Card {
                        title: "Interface: " + root.detail.name;

                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Status:";
                                width: 132px;
                                color: #6a6a6a;
                                font-size: 13px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                            VerticalLayout {
                                alignment: center;
                                StatusDot { on: root.detail.active; }
                            }
                            Text {
                                text: root.detail.active ? "Active" : "Inactive";
                                color: #1b1b1b;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        if root.detail.active && root.detail.health != "": HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: "Connection:";
                                width: 132px;
                                color: #6a6a6a;
                                font-size: 13px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.detail.health;
                                color: root.detail.health-good ? #2cbe4e : #b06a00;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        // Stuck-handshake banner: the tunnel is up but no
                        // handshake has completed, so it's not actually
                        // connected. A thin amber row that points at Diagnose.
                        if root.conn-warning != "": Rectangle {
                            background: #fff6e0;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #e6c560;
                            HorizontalLayout {
                                padding: 8px;
                                spacing: 8px;
                                Text {
                                    text: root.conn-warning;
                                    color: #6a5300;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                                VerticalLayout {
                                    alignment: center;
                                    PushButton {
                                        text: "Diagnose";
                                        tooltip: "Check why this tunnel isn't connecting";
                                        clicked => { root.diagnose-conn(root.detail.name); }
                                    }
                                }
                            }
                        }

                        if root.detail.active && root.detail.speed != "": DetailRow {
                            label: "Speed:";
                            value: root.detail.speed;
                        }

                        DetailRow {
                            label: "Public key:";
                            value: root.detail.public-key;
                            copyable: true;
                            copy => { root.copy-value(root.detail.public-key); }
                        }
                        if root.detail.listen-port != "": DetailRow {
                            label: "Listen port:";
                            value: root.detail.listen-port;
                            copyable: true;
                            copy => { root.copy-value(root.detail.listen-port); }
                        }
                        if root.detail.addresses != "": DetailRow {
                            label: "Addresses:";
                            value: root.detail.addresses;
                            copyable: true;
                            copy => { root.copy-value(root.detail.addresses); }
                        }
                        if root.detail.dns != "": DetailRow {
                            label: "DNS servers:";
                            value: root.detail.dns;
                            copyable: true;
                            copy => { root.copy-value(root.detail.dns); }
                        }

                        // Start-on-boot toggle (wg-quick@<name> systemd unit).
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: ""; width: 132px; }
                            CheckBox {
                                text: "Start on boot";
                                checked: root.detail.autostart;
                                toggled => {
                                    root.set-autostart(root.detail.name, self.checked);
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        // Activate / Deactivate + Show QR — below the details,
                        // aligned under the value column (matches the Windows client).
                        HorizontalLayout {
                            padding-top: 6px;
                            spacing: 8px;
                            Rectangle { width: 132px; }
                            PushButton {
                                text: root.detail.active ? "Deactivate" : "Activate";
                                primary: !root.detail.active;
                                tooltip: root.detail.active ? "Take the tunnel down" : "Bring the tunnel up";
                                clicked => {
                                    if (root.detail.active) {
                                        root.deactivate(root.detail.name);
                                    } else {
                                        root.activate(root.detail.name);
                                    }
                                }
                            }
                            PushButton {
                                text: "Diagnose";
                                tooltip: "Check why this tunnel isn't connecting";
                                clicked => { root.diagnose-conn(root.detail.name); }
                            }
                            PushButton {
                                text: "Show QR";
                                tooltip: "Show as a QR code to scan on a phone";
                                clicked => { root.show-qr(root.detail.name); }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        // ---- Advanced (progressive disclosure) ----
                        // An always-visible, subtly-styled disclosure header. The
                        // expert/raw runtime actions below only show once expanded,
                        // so the user can SEE they exist instead of a hidden mode.
                        Rectangle {
                            height: 28px;
                            adv-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.show-advanced = !root.show-advanced;
                                    root.persist-advanced(root.show-advanced);
                                }
                            }
                            HorizontalLayout {
                                Text { text: ""; width: 132px; }
                                Text {
                                    text: root.show-advanced ? "Advanced ▴" : "Advanced ▾";
                                    color: adv-touch.has-hover ? #4a4a4a : #8a8a8a;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }

                        if root.show-advanced: HorizontalLayout {
                            spacing: 8px;
                            Text { text: ""; width: 132px; }
                            CheckBox {
                                text: "Kill switch";
                                checked: root.detail.killswitch;
                                enabled: root.detail.active;
                                toggled => {
                                    root.set-killswitch(root.detail.name, self.checked);
                                }
                            }
                            Text {
                                text: root.detail.active ? "blocks non-local traffic outside this tunnel" : "requires an active tunnel";
                                color: #6a6a6a;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        if root.show-advanced: HorizontalLayout {
                            spacing: 8px;
                            Rectangle { width: 132px; }
                            if root.detail.active: PushButton {
                                text: "Running cfg";
                                tooltip: "Copy the live running config (wg showconf)";
                                clicked => { root.show-running(root.detail.name); }
                            }
                            if root.detail.active: PushButton {
                                text: "Save live";
                                tooltip: "Save the running state to disk (wg-quick save)";
                                clicked => { root.persist-live(root.detail.name); }
                            }
                            if !root.detail.active: Text {
                                text: "Activate the tunnel to access live runtime actions.";
                                color: #6a6a6a;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }

                    // ---- Peer cards ----
                    for p in root.detail.peers: Card {
                        title: "Peer";
                        DetailRow {
                            label: "Public key:";
                            value: p.public-key;
                            copyable: true;
                            copy => { root.copy-value(p.public-key); }
                        }
                        if p.preshared: DetailRow {
                            label: "Preshared key:";
                            value: "enabled";
                        }
                        if p.allowed-ips != "": DetailRow {
                            label: "Allowed IPs:";
                            value: p.allowed-ips;
                            copyable: true;
                            copy => { root.copy-value(p.allowed-ips); }
                        }
                        if p.endpoint != "": DetailRow {
                            label: "Endpoint:";
                            value: p.endpoint;
                            copyable: true;
                            copy => { root.copy-value(p.endpoint); }
                        }
                        if p.keepalive != "": DetailRow {
                            label: "Persistent keepalive:";
                            value: p.keepalive == "0" ? "off" : (p.keepalive + " seconds");
                        }
                        if p.latest-handshake != "": DetailRow {
                            label: "Latest handshake:";
                            value: p.latest-handshake;
                        }
                        if p.transfer != "": DetailRow {
                            label: "Transfer:";
                            value: p.transfer;
                        }
                    }
                }
            }

            // ---- bottom-right action bar: Edit ----
            Rectangle {
                height: 46px;
                background: #fafafa;
                Rectangle { y: 0; height: 1px; background: #e0e0e0; }
                HorizontalLayout {
                    padding: 8px;
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    if root.has-selection: VerticalLayout {
                        alignment: center;
                        PushButton {
                            text: "Edit";
                            tooltip: "Edit this tunnel's configuration";
                            tooltip-align: "right";
                            clicked => { root.begin-edit(root.detail.name); }
                        }
                    }
                }
            }
            }
        }
        }

        // ===================== Log tab =====================
        if root.active-tab == 1: Rectangle {
            vertical-stretch: 1;
            background: white;
            VerticalLayout {
                // The log view. A virtualized ListView of one Text per line
                // (only visible rows render, no editor caret/Timer) — replaces
                // the old whole-buffer read-only TextEdit that relaid-out the
                // entire log every frame while scrolling.
                ListView {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;
                    for line in root.log-lines: DocLine {
                        text: line;
                        copy(t) => { root.copy-line(t); }
                    }
                }
                // Discoverability hint for the per-line click-to-copy interaction.
                Rectangle {
                    height: 20px;
                    background: #fafafa;
                    HorizontalLayout {
                        padding-left: 10px;
                        Text {
                            text: "Tip: click a line to copy it · Copy for everything";
                            color: #8a8a8a;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle {
                    height: 46px;
                    background: #fafafa;
                    Rectangle { y: 0; height: 1px; background: #e0e0e0; }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Refresh";
                                clicked => { root.refresh-log(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            LineEdit {
                                width: 160px;
                                placeholder-text: "Filter…";
                                text: root.log-filter;
                                edited(s) => { root.log-filter = s; root.apply-log-filter(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            CheckBox {
                                text: "This tunnel";
                                checked: root.log-this-tunnel;
                                toggled => { root.log-this-tunnel = self.checked; root.apply-log-filter(); }
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Save";
                                clicked => { root.save-log(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Clear";
                                clicked => { root.clear-log(); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Copy";
                                clicked => { root.copy-log(); }
                            }
                        }
                    }
                }
            }
        }

        // ===================== Backup tab =====================
        if root.active-tab == 2: Rectangle {
            vertical-stretch: 1;
            background: white;
            VerticalLayout {
                // Column header
                Rectangle {
                    height: 28px;
                    background: #f3f3f3;
                    Rectangle { y: parent.height - 1px; height: 1px; background: #e0e0e0; }
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 12px;
                        Text { text: "When"; width: 170px; vertical-alignment: center; color: #666; font-size: 12px; }
                        Text { text: "Size"; width: 90px; vertical-alignment: center; color: #666; font-size: 12px; }
                        Text { text: "Tunnels"; width: 70px; vertical-alignment: center; color: #666; font-size: 12px; }
                        Text { text: "File"; vertical-alignment: center; color: #666; font-size: 12px; }
                    }
                }
                ListView {
                    vertical-stretch: 1;
                    for b[i] in root.backups: Rectangle {
                        height: 30px;
                        background: i == root.backup-sel ? #e8f0fe : white;
                        TouchArea { clicked => { root.backup-sel = i; } }
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 12px;
                            Text { text: b.date; width: 170px; vertical-alignment: center; font-size: 12px; color: #1b1b1b; }
                            Text { text: b.size; width: 90px; vertical-alignment: center; font-size: 12px; color: #444; }
                            Text { text: b.count; width: 70px; vertical-alignment: center; font-size: 12px; color: #444; }
                            Text { text: b.name; vertical-alignment: center; font-size: 12px; color: #888; overflow: elide; }
                        }
                    }
                }
                // Empty hint
                if root.backups.length == 0: Rectangle {
                    vertical-stretch: 1;
                    Text {
                        text: "No backups yet.\nClick “New backup” to archive every tunnel config.";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        color: #888;
                    }
                }
                // Action bar
                Rectangle {
                    height: 46px;
                    background: #fafafa;
                    Rectangle { y: 0; height: 1px; background: #e0e0e0; }
                    HorizontalLayout {
                        padding: 8px;
                        spacing: 6px;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "New backup";
                                clicked => { root.backup-create(); }
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Restore";
                                enabled: root.backup-sel >= 0;
                                clicked => { root.backup-restore(root.backups[root.backup-sel].name); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Export";
                                enabled: root.backup-sel >= 0;
                                clicked => { root.backup-export(root.backups[root.backup-sel].name); }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            PushButton {
                                text: "Delete";
                                enabled: root.backup-sel >= 0;
                                clicked => { root.backup-delete(root.backups[root.backup-sel].name); }
                            }
                        }
                    }
                }
            }
        }
    }

    // ===================== status bar =====================
    if root.status != "": Rectangle {
        x: 0;
        y: parent.height - 24px;
        width: parent.width;
        height: 24px;
        background: #2f2f2f;
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            Text {
                text: root.status;
                color: white;
                font-size: 12px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    // ===================== tooltip overlay =====================
    // The VERY LAST child of the window root, so it renders on top of every
    // panel/popup region and is never clipped. Driven by TooltipState, which any
    // hovered PushButton/IconButton populates. Centered over the hovered button,
    // clamped inside the window, and floated just above it.
    if TooltipState.text != "": Rectangle {
        x: min(root.width - self.width - 6px, max(6px, TooltipState.ax + TooltipState.aw / 2 - self.width / 2));
        y: max(4px, TooltipState.ay - self.height - 6px);
        width: tip-label.preferred-width + 16px;
        height: tip-label.preferred-height + 10px;
        background: #2f2f2f;
        border-radius: 4px;
        tip-label := Text {
            x: 8px;
            y: 5px;
            text: TooltipState.text;
            color: white;
            font-size: 11px;
        }
    }
}

import { Button as StdButton } from "std-widgets.slint";

// ===========================================================================
// Editor as a SEPARATE top-level window. A fresh window gets a clean initial
// paint, so its text-input widgets render immediately — unlike an in-place
// overlay, which on this Wayland setup stays blank until clicked.
// ===========================================================================
// A single labelled field used by the structured (form) editor view. An
// optional one-line `hint` is shown muted underneath to explain the field in
// plain words (progressive inline guidance).
component FormField {
    in property <string> label;
    in property <string> placeholder;
    in property <string> hint: "";
    in-out property <string> value;
    callback edited;
    VerticalLayout {
        spacing: 2px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.label;
                width: 120px;
                color: #6a6a6a;
                font-size: 12px;
                vertical-alignment: center;
            }
            LineEdit {
                horizontal-stretch: 1;
                text <=> root.value;
                placeholder-text: root.placeholder;
                edited => { root.edited(); }
            }
        }
        if root.hint != "": Text {
            x: 128px;
            text: root.hint;
            color: #8a8a8a;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

export component EditWindow inherits Window {
    title: "Edit Tunnel";
    width: 600px;
    height: 600px;

    in property <bool> is-new: false;
    in-out property <string> tunnel-name: "";
    in-out property <string> config-text: "";
    in property <string> error: "";
    in property <string> warning: "";
    in property <string> public-key: "";

    // Form view: structured fields. `form-mode` toggles between the form and
    // the raw config text; peer-index/peer-count drive multi-peer navigation.
    in-out property <bool> form-mode: false;
    // Progressive disclosure inside the form: the rarely-touched interface
    // fields (Listen port, MTU) live under an "Advanced fields ▾" header that
    // starts collapsed, so the default form shows only the common path.
    in-out property <bool> show-advanced-fields: false;
    in-out property <int> peer-index: 0;
    in property <int> peer-count: 1;
    in property <string> peer-label: "1 of 1";
    in-out property <string> f-private-key;
    in-out property <string> f-address;
    in-out property <string> f-dns;
    in-out property <string> f-listen-port;
    in-out property <string> f-mtu;
    in-out property <string> f-peer-public-key;
    in-out property <string> f-preshared-key;
    in-out property <string> f-allowed-ips;
    in-out property <string> f-endpoint;
    in-out property <string> f-keepalive;

    callback save(string, string);
    callback cancel();
    callback generate-key();
    callback generate-psk();
    callback config-changed(string);
    callback fields-changed();
    callback switch-mode(bool);
    callback peer-prev();
    callback peer-next();
    callback peer-add();
    callback peer-remove();
    callback create-preset(string);
    callback copy(string);
    callback save-and-activate(string, string);
    callback show-help();

    // Force the light palette so the text inputs use dark-text-on-light fills —
    // which is what makes them visible on a white background. (No `min-height`
    // on the TextEdit either — Slint #6896.)
    init => { Palette.color-scheme = ColorScheme.light; }

    background: white;
    Rectangle {
        VerticalLayout {
            padding: 18px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: root.is-new ? "Create new tunnel" : ("Edit “" + root.tunnel-name + "”");
                    font-size: 16px;
                    font-weight: 700;
                    color: #1b1b1b;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: center;
                    PushButton {
                        text: "? Help";
                        tooltip: "Open the in-app help guide";
                        tooltip-align: "right";
                        clicked => { root.show-help(); }
                    }
                }
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                Text {
                    text: "Name:";
                    width: 56px;
                    color: #6a6a6a;
                    vertical-alignment: center;
                }
                LineEdit {
                    horizontal-stretch: 1;
                    text <=> root.tunnel-name;
                    placeholder-text: "tunnel name";
                }
            }

            // Public key — derived live from the PrivateKey in the config
            // (matches the WireGuard for Windows "create tunnel" dialog).
            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                Text {
                    text: "Public key:";
                    width: 80px;
                    color: #6a6a6a;
                    vertical-alignment: center;
                }
                Text {
                    text: root.public-key != "" ? root.public-key : "—";
                    color: #1b1b1b;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                PushButton {
                    text: "Copy";
                    enabled: root.public-key != "";
                    clicked => { root.copy(root.public-key); }
                }
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                PushButton {
                    text: "Generate keypair";
                    tooltip: "Generate a new private/public key";
                    clicked => { root.generate-key(); }
                }
                PushButton {
                    text: "Generate PSK";
                    tooltip: "Generate a preshared key for the peer";
                    clicked => { root.generate-psk(); }
                }
                PushButton {
                    text: "Copy config";
                    clicked => { root.copy(root.config-text); }
                }
                Rectangle { horizontal-stretch: 1; }
            }

            if root.is-new: Rectangle {
                vertical-stretch: 0;
                background: #f7fbff;
                border-color: #d6e9fb;
                border-width: 1px;
                border-radius: 3px;
                HorizontalLayout {
                    padding: 8px;
                    spacing: 8px;
                    Text {
                        text: "Preset:";
                        width: 56px;
                        color: #5a5a5a;
                        vertical-alignment: center;
                    }
                    PushButton {
                        text: "Interface only";
                        tooltip: "Generate only an [Interface] section";
                        clicked => { root.create-preset("interface"); }
                    }
                    PushButton {
                        text: "Full tunnel";
                        tooltip: "Default AllowedIPs route all traffic through the peer";
                        clicked => { root.create-preset("full"); }
                    }
                    PushButton {
                        text: "Split tunnel";
                        tooltip: "Default AllowedIPs route only a private subnet";
                        clicked => { root.create-preset("split"); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }

            // Mode toggle: structured fields vs. raw config text.
            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 0px;
                TabButton {
                    text: "Edit fields";
                    selected: root.form-mode;
                    clicked => { root.switch-mode(true); }
                }
                TabButton {
                    text: "Config text";
                    selected: !root.form-mode;
                    clicked => { root.switch-mode(false); }
                }
                Rectangle { horizontal-stretch: 1; }
            }

            // ---- structured form view ----
            if root.form-mode: ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    padding-right: 6px;
                    spacing: 6px;
                    Text {
                        text: "Interface";
                        font-size: 13px;
                        font-weight: 700;
                        color: #1b1b1b;
                    }
                    FormField {
                        label: "Private key";
                        placeholder: "base64 private key";
                        hint: "Your secret — never share it; use Generate keypair";
                        value <=> root.f-private-key;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "Address";
                        placeholder: "10.0.0.2/32, fd00::2/128";
                        hint: "Your IP inside the tunnel, e.g. 10.100.0.17/24";
                        value <=> root.f-address;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "DNS";
                        placeholder: "1.1.1.1, 8.8.8.8";
                        hint: "DNS server while connected (optional), e.g. 1.1.1.1";
                        value <=> root.f-dns;
                        edited => { root.fields-changed(); }
                    }

                    // ---- Advanced interface fields (collapsed by default) ----
                    TouchArea {
                        height: 22px;
                        mouse-cursor: pointer;
                        clicked => { root.show-advanced-fields = !root.show-advanced-fields; }
                        Text {
                            x: 0;
                            text: (root.show-advanced-fields ? "▾ " : "▸ ") + "Advanced fields";
                            color: #5a5a5a;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    if root.show-advanced-fields: FormField {
                        label: "Listen port";
                        placeholder: "optional";
                        hint: "Local UDP port to listen on (optional, usually auto)";
                        value <=> root.f-listen-port;
                        edited => { root.fields-changed(); }
                    }
                    if root.show-advanced-fields: FormField {
                        label: "MTU";
                        placeholder: "optional";
                        hint: "Packet size (optional); lower to e.g. 1380 on flaky links";
                        value <=> root.f-mtu;
                        edited => { root.fields-changed(); }
                    }
                    Rectangle { height: 4px; }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Peer";
                            font-size: 13px;
                            font-weight: 700;
                            color: #1b1b1b;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.peer-label;
                            color: #6a6a6a;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        PushButton {
                            text: "Prev";
                            enabled: root.peer-index > 0;
                            clicked => { root.peer-prev(); }
                        }
                        PushButton {
                            text: "Next";
                            enabled: root.peer-index + 1 < root.peer-count;
                            clicked => { root.peer-next(); }
                        }
                        PushButton {
                            text: "Add peer";
                            clicked => { root.peer-add(); }
                        }
                        PushButton {
                            text: "Remove";
                            enabled: root.peer-count > 1;
                            clicked => { root.peer-remove(); }
                        }
                    }
                    FormField {
                        label: "Public key";
                        placeholder: "peer's base64 public key";
                        hint: "The server's public key";
                        value <=> root.f-peer-public-key;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "Preshared key";
                        placeholder: "optional";
                        hint: "Optional extra shared secret; use Generate PSK";
                        value <=> root.f-preshared-key;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "Allowed IPs";
                        placeholder: "0.0.0.0/0, ::/0";
                        hint: "What routes into the tunnel — 0.0.0.0/0 = everything (full tunnel)";
                        value <=> root.f-allowed-ips;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "Endpoint";
                        placeholder: "host:51820";
                        hint: "Where to reach the server: host:port, e.g. 1.2.3.4:51820";
                        value <=> root.f-endpoint;
                        edited => { root.fields-changed(); }
                    }
                    FormField {
                        label: "Persistent keepalive";
                        placeholder: "optional, e.g. 25";
                        hint: "Keep-alive seconds (25 is typical behind NAT)";
                        value <=> root.f-keepalive;
                        edited => { root.fields-changed(); }
                    }
                }
            }

            // ---- raw config text view ----
            if !root.form-mode: TextEdit {
                vertical-stretch: 1;
                text <=> root.config-text;
                edited => { root.config-changed(self.text); }
            }

            Text {
                visible: root.warning != "";
                text: root.warning;
                color: #b06a00;
                font-size: 12px;
                wrap: word-wrap;
            }

            Text {
                visible: root.error != "";
                text: root.error;
                color: #c0392b;
                font-size: 12px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                alignment: end;
                PushButton {
                    text: "Cancel";
                    clicked => { root.cancel(); }
                }
                PushButton {
                    text: root.is-new ? "Create" : "Save";
                    primary: true;
                    clicked => { root.save(root.tunnel-name, root.config-text); }
                }
                if root.is-new: PushButton {
                    text: "Create & Activate";
                    primary: true;
                    clicked => { root.save-and-activate(root.tunnel-name, root.config-text); }
                }
            }
        }
    }
}

// ===========================================================================
// A small window that shows a tunnel's config as a QR code (scan it from the
// WireGuard mobile app to import the tunnel on a phone).
// ===========================================================================
export component QrWindow inherits Window {
    title: "Tunnel QR code";
    width: 360px;
    height: 430px;
    in property <string> name;
    in property <image> qr;

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 18px;
        spacing: 12px;
        alignment: start;
        Text {
            text: "Scan to import “" + root.name + "”";
            font-size: 15px;
            font-weight: 700;
            color: #1b1b1b;
            horizontal-alignment: center;
        }
        HorizontalLayout {
            alignment: center;
            Image {
                source: root.qr;
                width: 300px;
                height: 300px;
                image-rendering: pixelated;
            }
        }
        Text {
            text: "On your phone: WireGuard → + → Scan from QR code.";
            color: #6a6a6a;
            font-size: 12px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// ===========================================================================
// Connection diagnostics window: a read-only monospace report explaining why a
// tunnel that reads "active" may not actually be connected.
// ===========================================================================
export component DiagWindow inherits Window {
    title: "Connection diagnostics";
    width: 560px;
    height: 380px;
    in property <[string]> report-lines;
    in property <string> full-text;
    in-out property <string> copied-hint: "";
    callback close-me();
    callback copy-line(string);
    callback copy-all();

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        // Virtualized ListView of one Text per line (was a whole-document
        // read-only TextEdit, which relaid out every frame while scrolling).
        // Each row is click-to-copy via DocLine.
        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            for line in root.report-lines: DocLine {
                text: line;
                copy(t) => { root.copy-line(t); }
            }
        }

        Text {
            text: "Tip: click a line to copy it · Copy all for everything";
            color: #8a8a8a;
            font-size: 11px;
        }

        HorizontalLayout {
            spacing: 8px;
            PushButton {
                text: "Copy all";
                tooltip: "Copy the whole report to the clipboard";
                clicked => { root.copy-all(); }
            }
            Text {
                text: root.copied-hint;
                color: #2f7d32;
                font-size: 12px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            PushButton {
                text: "Close";
                primary: true;
                clicked => { root.close-me(); }
            }
        }
    }
}

// ===========================================================================
// Help window: a scrollable, read-only view of the in-app guide (docs/help.md,
// embedded at build time and passed in from Rust). Slint has no markdown
// renderer, so the Rust side (md_items) tags each line with a kind and MdRow
// styles it — headings, bullets, code, and rules render cleanly, virtualized,
// still click-to-copy.
// ===========================================================================
export component HelpWindow inherits Window {
    title: "WireGuard — Help";
    width: 720px;
    height: 640px;
    in property <[DocItem]> items;
    in property <string> full-text;
    in-out property <string> copied-hint: "";
    callback close-me();
    callback copy-line(string);
    callback copy-all();

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        // Virtualized ListView of one styled MdRow per markdown line (was a
        // whole-document read-only TextEdit, which relaid out every frame while
        // scrolling). Each row is click-to-copy.
        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            for it in root.items: MdRow {
                item: it;
                copy(t) => { root.copy-line(t); }
            }
        }

        Text {
            text: "Tip: click a line to copy it · Copy all for everything";
            color: #8a8a8a;
            font-size: 11px;
        }

        HorizontalLayout {
            spacing: 8px;
            PushButton {
                text: "Copy all";
                tooltip: "Copy the whole guide to the clipboard";
                clicked => { root.copy-all(); }
            }
            Text {
                text: root.copied-hint;
                color: #2f7d32;
                font-size: 12px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            PushButton {
                text: "Close";
                primary: true;
                clicked => { root.close-me(); }
            }
        }
    }
}

// ===========================================================================
// Updates window: shows the installed version, a live status line, a
// [Check for updates] / [Update now] pair, and the embedded changelog.
// ===========================================================================
export component UpdateWindow inherits Window {
    title: "Updates";
    width: 640px;
    height: 600px;
    in property <string> installed: "";
    in property <string> status: "";
    in property <bool> update-available: false;
    in property <[DocItem]> changelog-items;
    in property <string> changelog-text;
    in-out property <string> copied-hint: "";
    callback check-updates();
    callback do-update();
    callback close-me();
    callback copy-line(string);
    callback copy-all();

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "Updates";
            font-size: 18px;
            font-weight: 800;
            color: #1b1b1b;
        }
        Text {
            text: "Installed: v" + root.installed;
            color: #444444;
            font-size: 13px;
        }
        Text {
            visible: root.status != "";
            text: root.status;
            color: #6a5300;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 8px;
            PushButton {
                text: "Check for updates";
                clicked => { root.check-updates(); }
            }
            PushButton {
                text: "Update now";
                primary: true;
                visible: root.update-available;
                enabled: root.update-available;
                clicked => { root.do-update(); }
            }
            Rectangle { horizontal-stretch: 1; }
        }

        Text {
            text: "Changelog";
            font-size: 13px;
            font-weight: 700;
            color: #1b1b1b;
        }
        // Virtualized ListView of one styled MdRow per changelog line (was a
        // whole-document read-only TextEdit, which relaid out every frame while
        // scrolling). Each row is click-to-copy.
        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            for it in root.changelog-items: MdRow {
                item: it;
                copy(t) => { root.copy-line(t); }
            }
        }

        Text {
            text: "Tip: click a line to copy it · Copy all for everything";
            color: #8a8a8a;
            font-size: 11px;
        }

        HorizontalLayout {
            spacing: 8px;
            PushButton {
                text: "Copy all";
                tooltip: "Copy the whole changelog to the clipboard";
                clicked => { root.copy-all(); }
            }
            Text {
                text: root.copied-hint;
                color: #2f7d32;
                font-size: 12px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            PushButton {
                text: "Close";
                primary: true;
                clicked => { root.close-me(); }
            }
        }
    }
}

// ===========================================================================
// About window.
// ===========================================================================
export component AboutWindow inherits Window {
    title: "About WireGuard GUI";
    width: 460px;
    height: 420px;
    in property <string> version;
    callback open-url(string);
    callback close-me();
    callback show-update();

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 28px;
        spacing: 0px;
        alignment: start;

        // ---- Brand: monogram tile + name + version ----
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 64px;
                height: 64px;
                border-radius: 14px;
                background: #0078d4;
                Text {
                    text: "WG";
                    color: white;
                    font-size: 26px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { height: 14px; }

        Text {
            text: "WireGuard GUI";
            font-size: 23px;
            font-weight: 800;
            color: #1b1b1b;
            horizontal-alignment: center;
        }
        Rectangle { height: 3px; }
        Text {
            text: "Version " + root.version;
            color: #6a6a6a;
            font-size: 13px;
            horizontal-alignment: center;
        }

        Rectangle { height: 12px; }

        // ---- Tagline ----
        Text {
            text: "A native Linux GUI for plain WireGuard configs — wg, wg-quick, and a small privileged helper.";
            color: #444444;
            font-size: 13px;
            wrap: word-wrap;
            horizontal-alignment: center;
        }

        Rectangle { height: 18px; }

        // ---- Hairline separator ----
        Rectangle {
            height: 1px;
            background: #ececec;
        }

        Rectangle { height: 18px; }

        // ---- Links ----
        HorizontalLayout {
            alignment: center;
            spacing: 8px;
            PushButton {
                text: "GitHub";
                tooltip: "View the source on GitHub";
                clicked => { root.open-url("https://github.com/JamilleJung/wireguard-gui"); }
            }
            PushButton {
                text: "Check for updates";
                clicked => { root.show-update(); }
            }
            PushButton {
                text: "Buy me a coffee";
                tooltip: "Support development";
                tooltip-align: "right";
                clicked => { root.open-url("https://www.buymeacoffee.com/jamillejung"); }
            }
        }

        // ---- Push the legal fine print + Close to the bottom ----
        Rectangle { vertical-stretch: 1; min-height: 16px; }

        Text {
            text: "MIT License · Built with Rust + Slint";
            color: #8a8a8a;
            font-size: 11px;
            horizontal-alignment: center;
        }
        Rectangle { height: 4px; }
        Text {
            text: "WireGuard is a registered trademark of Jason A. Donenfeld. This is an independent, unofficial client.";
            color: #a0a0a0;
            font-size: 10px;
            wrap: word-wrap;
            horizontal-alignment: center;
        }

        Rectangle { height: 16px; }

        HorizontalLayout {
            alignment: center;
            PushButton {
                text: "Close";
                primary: true;
                clicked => { root.close-me(); }
            }
        }
    }
}

// ===========================================================================
// First-run Setup wizard: shown when a critical requirement is missing, so new
// users get friendly guidance instead of an empty technical screen.
// ===========================================================================
export component SetupWindow inherits Window {
    title: "Set up WireGuard";
    width: 580px;
    height: 480px;
    in property <[CheckItem]> checks;
    in property <string> commands: "";
    in property <bool> show-commands: false;
    in property <string> busy: "";
    callback fix-automatically();
    callback toggle-commands();
    callback re-check();
    callback skip();

    init => { Palette.color-scheme = ColorScheme.light; }
    background: white;

    VerticalLayout {
        padding: 20px;
        spacing: 10px;

        Text {
            text: "Welcome to WireGuard";
            font-size: 19px;
            font-weight: 800;
            color: #1b1b1b;
        }
        Text {
            text: "Let's check your system is ready. Nothing is changed without your confirmation, and no tunnels are connected.";
            color: #555555;
            font-size: 13px;
            wrap: word-wrap;
        }

        for c in root.checks: HorizontalLayout {
            spacing: 8px;
            Text {
                text: c.ok ? "OK" : (c.warn ? "!" : "X");
                color: c.ok ? #2cbe4e : (c.warn ? #b06a00 : #c0392b);
                font-weight: 800;
                font-size: 13px;
                width: 26px;
                vertical-alignment: center;
            }
            VerticalLayout {
                Text {
                    text: c.name;
                    color: #1b1b1b;
                    font-size: 13px;
                    font-weight: 600;
                }
                Text {
                    text: c.detail;
                    color: #6a6a6a;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }

        if root.show-commands && root.commands != "": Rectangle {
            background: #f4f4f4;
            border-radius: 4px;
            VerticalLayout {
                padding: 8px;
                Text {
                    text: root.commands;
                    font-size: 12px;
                    color: #1b1b1b;
                    wrap: word-wrap;
                }
            }
        }
        if root.busy != "": Text {
            text: root.busy;
            color: #1e66f5;
            font-size: 13px;
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: 8px;
            PushButton {
                text: "Fix automatically";
                primary: true;
                tooltip: "Install missing pieces with your package manager (asks for your password)";
                clicked => { root.fix-automatically(); }
            }
            PushButton {
                text: "Show commands";
                clicked => { root.toggle-commands(); }
            }
            PushButton {
                text: "Re-check";
                clicked => { root.re-check(); }
            }
            Rectangle { horizontal-stretch: 1; }
            PushButton {
                text: "Skip for now";
                clicked => { root.skip(); }
            }
        }
    }
}
